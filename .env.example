# Database (Railway o local MySQL 8)
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/flowtex?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=root

# Server
SPRING_PROFILES_ACTIVE=dev
PORT=8080

# Security
JWT_SECRET=please-change-this-secret-with-at-least-256-bits-of-entropy-please-please
JWT_EXPIRATION_MS=86400000

# CORS (lista separada por comas)
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# AI - Groq (gratis: console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
